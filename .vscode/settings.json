{
    "go.lintTool": "golangci-lint",
    "go.formatTool": "custom",
    "go.formatFlags": [
        "fmt",
        "--stdin"
    ],
    "go.alternateTools": {
        "customFormatter": "golangci-lint"
    },
    // --- typescript & react stuffs
    // tell the biome extension where our biome binary is (in the
    // node_modules folder of the web app)
    "biome.lsp.bin": "./apps/web/node_modules/@biomejs/biome/bin/biome",
    "files.watcherExclude": {
        "**/routeTree.gen.ts": true
    },
    "search.exclude": {
        "**/routeTree.gen.ts": true
    },
    "files.readonlyInclude": {
        "**/routeTree.gen.ts": true
    },
    "[javascript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[json]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[css]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "editor.codeActionsOnSave": {
        "source.organizeImports.biome": "explicit"
    }
}